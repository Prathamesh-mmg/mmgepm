{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=MMG_EPM;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True;",
    "Redis": ""
  },
  "JwtSettings": {
    "Secret":        "MMG_EPM_SECRET_KEY_CHANGE_THIS_TO_SOMETHING_LONG_AND_RANDOM_MIN_32",
    "Issuer":        "mmgepm.local",
    "Audience":      "mmgepm.local",
    "ExpiryMinutes": "60"
  },
  "FileStorage": {
    "BasePath":       "Uploads",
    "MaxFileSizeMB":  50
  },
  "Smtp": {
    "Host":         "smtp.gmail.com",
    "Port":         "587",
    "Username":     "",
    "Password":     "",
    "SenderName":   "MMG EPM",
    "SenderEmail":  "noreply@mmgepm.com"
  },
  "AllowedOrigins": [
    "http://localhost:5173",
    "http://localhost:3000"
  ],
  "Serilog": {
    "Using":  ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default":    "Information",
      "Override": {
        "Microsoft":                           "Warning",
        "Microsoft.EntityFrameworkCore":       "Warning",
        "System":                              "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path":                "Logs/mmgepm-.log",
          "rollingInterval":     "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate":      "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithProcessId"]
  },
  "Hangfire": {
    "WorkerCount": 5
  },
  "AllowedHosts": "*"
}
